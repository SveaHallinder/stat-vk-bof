# --- Build artifacts & dependencies (rebuilt inside the image) ---
node_modules
dist
build
.cache
.turbo
coverage
.nyc_output

# --- Source control & CI metadata (never needed in images) ---
.git
.gitignore
.gitattributes

# --- Environment files (NEVER bake secrets into image layers) ---
# Backend MUST NOT contain any committed env files; secrets come from
# Kubernetes Secrets at runtime.
.env
.env.*
env
env.*

# --- Editor / OS / tool clutter ---
.vscode
.idea
.cursor
.gstack
.claude
.DS_Store
*.swp
*.swo

# --- Logs & runtime ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Local databases / certificates / keys ---
*.sqlite
*.db
*.pem
*.key
*.crt
*.p12

# --- Tests & docs (not needed at runtime) ---
test
__tests__
*.test.ts
*.test.js
*.spec.ts
*.spec.js
*.md
docs
ecosystem.config.js
