# Environment variables — secrets must NEVER be committed
# Vite convention: .env.production and .env.staging may contain ONLY public
# VITE_* values that get baked into the public client bundle. Any sensitive
# values (API keys, tokens, DB credentials) MUST go in .env.local or
# .env.[mode].local — these stay gitignored. Backend env files are NEVER
# committed under any circumstance (they hold JWT_SECRET, DATABASE_URL, etc.).
.env
.env.local
.env.development
.env.development.local
.env.production.local
.env.staging.local
.env.test
.env.test.local
.env.*.local

# Backend environment files — ALL backend env files are gitignored.
backend/.env
backend/.env.*
backend/env
backend/env.*

# Database
*.sqlite
*.db

# SSL certificates
*.pem
*.key
*.crt
*.p12
.gstack/
